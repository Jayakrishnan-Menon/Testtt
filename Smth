% Bit‑reverse the product for IFFT input (correct order)
RESIB = PRESI(BITREV+1);
RESQB = PRESQ(BITREV+1);

% --------------------------------------------------------------
% IFFT using conjugated twiddles
% --------------------------------------------------------------
Y_re = int16(bitshift(RESIB,0));
Y_im = int16(bitshift(RESQB,0));

for stage = 1:11
    len = 2^stage;
    half = len / 2;
    tw_step = N / len;
    for base = 0:len:N-1
        for i = 0:half-1
            p = base + i;
            q = p + half;
            tw = i * tw_step;
            w_re = int32(TWIDI(tw+1));
            w_im = -int32(TWIDQ(tw+1));   % conjugate for IFFT

            a_re = int32(Y_re(p+1)); a_im = int32(Y_im(p+1));
            b_re = int32(Y_re(q+1)); b_im = int32(Y_im(q+1));

            prod_re = bitshift(((b_re * w_re) - (b_im * w_im)) + 16384, -15);  % fixed: -15
            prod_im = bitshift(((b_re * w_im) + (b_im * w_re)) + 16384, -15);

            new_a_re = bitshift(a_re + prod_re, -1);
            new_a_im = bitshift(a_im + prod_im, -1);
            new_b_re = bitshift(a_re - prod_re, -1);
            new_b_im = bitshift(a_im - prod_im, -1);

            Y_re(p+1) = int16(new_a_re);
            Y_im(p+1) = int16(new_a_im);
            Y_re(q+1) = int16(new_b_re);
            Y_im(q+1) = int16(new_b_im);
        end
    end
end

