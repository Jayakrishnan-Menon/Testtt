scale = 32768;  % 2^15

TI = int16([real(tx_analytic), (zeros(2048-length(tx_analytic),1))']*scale); TI(TI == 32768) = 32767;
TQ = int16([imag(tx_analytic), (zeros(2048-length(tx_analytic),1))']*scale); TQ(TQ == 32768) = 32767;
RI = int16([real(rx_analytic), (zeros(2048-length(rx_analytic),1))']*scale); RI(RI == 32768) = 32767;
RQ = int16([imag(rx_analytic), (zeros(2048-length(rx_analytic),1))']*scale); RQ(RQ == 32768) = 32767;
##figure;
##subplot(2,1,1);
##plot3(1:2048,TI,TQ);
##subplot(2,1,2);
##plot3(1:2048,RI,RQ);

BITREV = bin2dec(fliplr(dec2bin(0:2048-1)));
TIB = TI(BITREV+1);
TQB = TQ(BITREV+1);
RIB = RI(BITREV+1);
RQB = RQ(BITREV+1);

TWIDFACT = zeros(1024,1);
for k = 0:(2048/2 - 1)
    TWIDFACT(k+1) = exp(-2i * pi * k / 2048);
end

TWIDI = int16(real(TWIDFACT) * scale); TWIDI(TWIDI == 32768) = 32767;
TWIDQ = int16(imag(TWIDFACT) * scale); TWIDQ(TWIDQ == 32768) = 32767;
##figure;
##plot3(1:1024,TWIDI,TWIDQ);

% ----- Both signals already bit‑reversed and scaled -----
% TIB, TQB = TX (bit‑reversed, Q1.15)
% RIB, RQB = RX (bit‑reversed, Q1.15)

N = 2048;
% Copy to work arrays (int16)
X1_re = bitshift(TIB, -0);   X1_im = bitshift(TQB, -0);
X2_re = bitshift(RIB, -0);   X2_im = bitshift(RQB, -0);

% ----- 11 stages of radix‑2 DIT FFT (corrected loop) -----
for stage = 1:11
    len = 2^stage;
    half = len / 2;
    tw_step = N / len;          % twiddle index increment

    for base = 0:len:N-1        % <-- corrected: base steps by len, not block
        for i = 0:half-1
            p = base + i;
            q = p + half;
            tw = i * tw_step;    % twiddle index (0‑based)

            % Load twiddle (int16 -> int32)
            w_re = int32(TWIDI(tw+1));
            w_im = int32(TWIDQ(tw+1));

            % ----- Process TX signal -----
            a1_re = int32(X1_re(p+1)); a1_im = int32(X1_im(p+1));
            b1_re = int32(X1_re(q+1)); b1_im = int32(X1_im(q+1));
            % Product: b1 * w with rounding (add 2^14 = 16384 before shift by 15)
            prod1_re = bitshift(((b1_re * w_re) - (b1_im * w_im)) + 16384, -15);
            prod1_im = bitshift(((b1_re * w_im) + (b1_im * w_re)) + 16384, -15);
            % Butterfly with scaling by 0.5 (>>1)
            new_a1_re = bitshift(a1_re + prod1_re, -1);
            new_a1_im = bitshift(a1_im + prod1_im, -1);
            new_b1_re = bitshift(a1_re - prod1_re, -1);
            new_b1_im = bitshift(a1_im - prod1_im, -1);
            X1_re(p+1) = int16(new_a1_re); X1_im(p+1) = int16(new_a1_im);
            X1_re(q+1) = int16(new_b1_re); X1_im(q+1) = int16(new_b1_im);

            % ----- Process RX signal (identical) -----
            a2_re = int32(X2_re(p+1)); a2_im = int32(X2_im(p+1));
            b2_re = int32(X2_re(q+1)); b2_im = int32(X2_im(q+1));
            prod2_re = bitshift(((b2_re * w_re) - (b2_im * w_im)) + 16384, -15);
            prod2_im = bitshift(((b2_re * w_im) + (b2_im * w_re)) + 16384, -15);
            new_a2_re = bitshift(a2_re + prod2_re, -1);
            new_a2_im = bitshift(a2_im + prod2_im, -1);
            new_b2_re = bitshift(a2_re - prod2_re, -1);
            new_b2_im = bitshift(a2_im - prod2_im, -1);
            X2_re(p+1) = int16(new_a2_re); X2_im(p+1) = int16(new_a2_im);
            X2_re(q+1) = int16(new_b2_re); X2_im(q+1) = int16(new_b2_im);
        end
    end
end

